generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  buyer
  seller
  admin
}

enum ListingStatus {
  active
  pending
  sold
  rejected
  archived
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum SellerType {
  owner
  broker
  dealer
}

enum PlateType {
  standard
  premium
  vip
}

enum OfferStatus {
  pending
  accepted
  rejected
  withdrawn
}

enum InquiryStatus {
  open
  closed
}

enum ReportStatus {
  open
  resolved
  dismissed
}

enum ContactDepartment {
  sales
  buyer_support
  seller_operations
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  phone              String?            @unique
  fullName           String
  passwordHash       String
  role               UserRole           @default(buyer)
  isEmailVerified    Boolean            @default(false)
  isPhoneVerified    Boolean            @default(false)
  refreshTokenHash   String?
  resetToken         String?
  resetTokenExpires  DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  sellerProfile      SellerProfile?
  adminProfile       AdminUser?
  listings           NumberPlateListing[]
  savedListings      SavedListing[]
  sentOffers         Offer[]            @relation("sentOffers")
  receivedOffers     Offer[]            @relation("receivedOffers")
  inquiries          Inquiry[]
  messagesSent       Message[]          @relation("messagesSent")
  messagesReceived   Message[]          @relation("messagesReceived")
  plateViews         PlateView[]
  notifications      Notification[]
}

model SellerProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  companyName      String?
  bio              String?
  emirate          String?
  city             String?
  verified         Boolean  @default(false)
  rating           Float    @default(0)
  totalSales       Int      @default(0)
  totalListings    Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminUser {
  id             String   @id @default(cuid())
  userId         String   @unique
  permissions    String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NumberPlateListing {
  id               String         @id @default(cuid())
  listingId         String         @unique
  emirate          String
  city             String
  plateCode        String
  plateNumber      String
  formattedPlate   String
  digitCount       Int
  priceAED         Int
  negotiable       Boolean        @default(false)
  featured         Boolean        @default(false)
  verified         Boolean        @default(false)
  sellerType       SellerType
  plateType        PlateType
  status           ListingStatus  @default(pending)
  views            Int            @default(0)
  favorites        Int            @default(0)
  inquiriesCount   Int            @default(0)
  description      String?
  ownershipStatus  String         @default("unknown")
  approvalStatus   ApprovalStatus @default(pending)
  isPublished      Boolean        @default(true)
  expiresAt        DateTime?
  slug             String         @unique
  userId           String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers           Offer[]
  inquiries        Inquiry[]
  savedBy          SavedListing[]
  plateViews       PlateView[]
  reports          ListingReport[]
  notifications    Notification[]

  @@index([emirate])
  @@index([plateCode])
  @@index([plateNumber])
  @@index([priceAED])
  @@index([featured])
  @@index([verified])
  @@index([status])
}

model SavedListing {
  id          String             @id @default(cuid())
  userId      String
  listingId   String
  createdAt   DateTime           @default(now())
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing     NumberPlateListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Offer {
  id              String             @id @default(cuid())
  listingId       String
  senderId        String
  receiverId      String
  amountAED       Int
  status          OfferStatus        @default(pending)
  note            String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  listing         NumberPlateListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sender          User               @relation("sentOffers", fields: [senderId], references: [id], onDelete: Cascade)
  receiver        User               @relation("receivedOffers", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id              String             @id @default(cuid())
  listingId       String
  userId          String
  subject         String
  message         String
  status          InquiryStatus      @default(open)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  listing         NumberPlateListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id            String   @id @default(cuid())
  senderId      String
  receiverId    String
  content       String
  readAt        DateTime?
  createdAt     DateTime @default(now())
  sender        User     @relation("messagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver      User     @relation("messagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
}

model PlateView {
  id            String             @id @default(cuid())
  listingId     String
  userId        String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime           @default(now())
  listing       NumberPlateListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ListingReport {
  id            String             @id @default(cuid())
  listingId     String
  reportedById  String?
  reason        String
  details       String?
  status        ReportStatus       @default(open)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  listing       NumberPlateListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Notification {
  id            String             @id @default(cuid())
  userId        String
  listingId     String?
  title         String
  body          String
  readAt        DateTime?
  createdAt     DateTime           @default(now())
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing       NumberPlateListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
}

model ContactSubmission {
  id            String            @id @default(cuid())
  fullName      String
  email         String
  department    ContactDepartment
  subject       String
  message       String
  createdAt     DateTime          @default(now())

  @@index([email])
  @@index([department])
  @@index([createdAt])
}
